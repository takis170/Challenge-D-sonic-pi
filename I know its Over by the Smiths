
use_bpm 98



#Drums measure 2 which is measure for each
define :drums do
  sample :drum_cymbal_pedal,sustain: 1  #closed hi hat
  sample :drum_bass_hard,sustain: 1
  sleep 0.5
  sample :drum_cymbal_pedal    #closed hi hat
  sleep 0.5
  sample :drum_cymbal_pedal    #closed hi hat
  sleep 0.5
  sample :drum_snare_hard
  sample :drum_cymbal_pedal    #closed hi hat
  sleep 0.5
  sample :drum_cymbal_pedal    #closed hi hat
  sleep 0.5
  sample :drum_cymbal_pedal    #closed hi hat
  sample :drum_bass_hard,sustain: 1
  sleep 0.5
end
define :electric_bass_3_3 do
  use_synth :fm
  with_fx :distortion, distort: 0.3 do
    play :a3
    sleep 1
    play :e3
    sleep 0.5
    play :a3
    sleep 1
    play :e3
  end
end

live_loop :background do
  drums
end

#measure_1_3/5
6.times do
  electric_bass_3_3
  sleep 0.5
end


use_synth :fm
with_fx :distortion, distort: 0.3 do
